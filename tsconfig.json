{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "outDir": "dist/frontend/static",
    "rootDir": "src/frontend",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/frontend/**/*.ts"]
}
